---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于 | Ad infinitum" description="关于这个个人网站">
  <section class="relative flex min-h-screen items-center overflow-hidden">
    <!-- 左侧文字区 -->
    <div class="relative z-10 w-full px-8 py-20 lg:w-1/3 lg:px-24">
      <!-- 斜杠背景装饰 -->
      <div class="slash-field pointer-events-none absolute -left-[20px] top-[calc(15%-80px)] h-[300px] w-[600px] font-display text-[210px] leading-none opacity-40">
        ////////////////////
      </div>

      <div class="relative">
        <p class="font-garamond text-sm uppercase tracking-[0.4em] text-[color:var(--color-muted)]" style="margin-left: 15px;">A B O U T</p>
        <h1 class="mt-2 font-cn text-7xl font-medium text-[color:var(--color-text)] sm:text-8xl">关于</h1>
        
        <div class="my-12">
          <div class="h-[1px] w-12 bg-[color:var(--color-line)]"></div>
        </div>

        <div class="space-y-4 font-cn text-lg leading-relaxed text-[color:var(--color-muted)]">
          <p>在文字的海洋里；</p>
          <p>无尽的思想无法被表达；</p>
          <p>我们能做到的，仅仅是将自己的自我紧紧抱在怀里，</p>
          <p>把自己的思想隐藏起来，</p>
          <p>以几乎荒谬的方式表达出来</p>
          <p>让一位幸运的旅人去挖掘这深藏的思想。</p>
        </div>

        <div class="my-12">
          <div class="h-[1px] w-12 bg-[color:var(--color-line)]"></div>
        </div>

        <div class="absolute bottom-0 left-0 rotate-12 font-display text-2xl text-[color:var(--color-soft)] opacity-30">//</div>
      </div>
    </div>

    <!-- 右侧图标矩阵 -->
    <div class="absolute right-0 top-[100px] hidden h-full w-2/3 overflow-hidden lg:block">
      <div class="grid h-full w-full grid-cols-16 gap-8 p-12">
        {Array.from({ length: 256 }).map(() => {
          const rand = Math.random();
          let opacity, blur, color;
          if (rand < 0.05) {
            opacity = 0.95;
            blur = 'none';
            color = 'var(--color-text)';
          } else {
            opacity = Math.random() * 0.7 + 0.1;
            blur = Math.random() < 0.3 ? `blur(${Math.random() * 8}px)` : 'none';
            color = 'var(--color-line)';
          }
          return (
            <div class="flex flex-col items-center justify-center" style={`opacity: ${opacity}; filter: ${blur}`}>
              <div class="h-9 w-9 rounded-full" style={`background: ${color}`}></div>
              <div class="mt-4 h-0 w-0 border-b-[54px] border-l-[27px] border-r-[27px] border-l-transparent border-r-transparent" style={`border-bottom-color: ${color}`}></div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
