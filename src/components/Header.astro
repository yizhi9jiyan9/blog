---
import ThemeToggle from './ThemeToggle.vue';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

const items = [
  { href: `${base}`, label: '主页', sublabel: 'HOME', match: '/', activeSvg: 'nav-home-active.svg', activeSvgDark: 'nav-home-active-dark.svg' },
  { href: `${base}posts/`, label: '文章', sublabel: 'ARTICLE', match: '/posts', activeSvg: 'nav-article-active.svg', activeSvgDark: 'nav-article-active-dark.svg' },
  { href: `${base}about/`, label: '关于', sublabel: 'ABOUT', match: '/about', activeSvg: 'nav-about-active.svg', activeSvgDark: 'nav-about-active-dark.svg' },
];

const isActive = (match: string) =>
  match === '/' ? currentPath === '/' : currentPath.startsWith(match);
---

<header class="fixed left-0 top-0 z-30 h-[93px] w-full overflow-hidden transition-all duration-300" id="site-header">
  <div class="pointer-events-none absolute left-0 top-0 h-[106px] w-full dark:hidden" style={`background-image: url('${base}images/header-bg-light.svg'); background-repeat: repeat-x; background-size: 1841px 106px; background-position: left top;`}></div>
  <div class="slash-field pointer-events-none absolute -left-[41px] -top-[68px] hidden h-[153px] w-[1980px] font-display text-[140px] leading-none dark:block">
    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
  </div>
  <nav class="relative h-full">
    <div class="site-nav-items absolute left-[5.625vw] top-0 flex h-[100px] items-start gap-8 xl:left-[108px]">
      {items.map((item) => (
        <a
          href={item.href}
          class="site-nav-item group relative block h-[100px] w-[126px] shrink-0 transition duration-200"
          aria-current={isActive(item.match) ? 'page' : undefined}
        >
          {isActive(item.match) ? (
            <>
              <div class="pointer-events-none absolute inset-0 -top-[7px] dark:hidden" style={`background-image: url('${base}images/${item.activeSvg}'); background-size: 126px 93px; background-repeat: no-repeat;`}></div>
              <div class="pointer-events-none absolute inset-0 -top-[7px] hidden dark:block" style={`background-image: url('${base}images/${item.activeSvgDark}'); background-size: 126px 93px; background-repeat: no-repeat;`}></div>
            </>
          ) : (
            <>
              <span class="site-nav-label absolute left-[15px] top-2 block w-24 font-cn text-5xl leading-[1.2] tracking-tight transition text-[color:var(--color-muted)] group-hover:text-[color:var(--color-text)]">
                {item.label}
              </span>
              <span class="site-nav-sublabel absolute left-[15px] top-[63px] block w-[97px] text-center font-garamond text-[15px] font-bold uppercase leading-none tracking-[0.45em] text-[color:var(--color-soft)]">
                {item.sublabel}
              </span>
            </>
          )}
        </a>
      ))}
    </div>
    <div class="absolute right-6 top-6 sm:right-12">
      <ThemeToggle client:load />
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  function updateHeaderHeight() {
    const isDark = document.documentElement.classList.contains('dark');
    header?.style.setProperty('height', isDark ? '93px' : '93px');
  }

  updateHeaderHeight();

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    
    if (currentScroll > 50) {
      header?.style.setProperty('backdrop-filter', 'blur(12px)');
      header?.style.setProperty('background', 'rgba(255, 255, 255, 0.01)');
    } else {
      header?.style.setProperty('backdrop-filter', 'none');
      header?.style.setProperty('background', 'transparent');
    }
    
    lastScroll = currentScroll;
  });

  // Handle dark mode
  const observer = new MutationObserver(() => {
    const currentScroll = window.scrollY;
    const isDark = document.documentElement.classList.contains('dark');
    
    updateHeaderHeight();
    
    if (currentScroll > 50) {
      header?.style.setProperty('background', isDark ? 'rgba(26, 26, 26, 0.01)' : 'rgba(255, 255, 255, 0.01)');
    }
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class']
  });
</script>
