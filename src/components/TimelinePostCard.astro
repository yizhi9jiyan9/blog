---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
}

const { title, description, date, tags, href } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(date);
---

<article class="group relative pl-10 md:pl-0">
  <time class="absolute -left-[152px] top-[4px] hidden w-28 font-garamond text-[20px] leading-none text-[color:var(--color-soft)] md:block" datetime={date.toISOString()}>
    {formattedDate}
  </time>
  <span class="absolute -left-[5px] top-[18px] hidden h-[14px] w-[14px] rounded-full border-2 border-[color:var(--color-line)] bg-[color:var(--color-bg)] md:block"></span>
  <div class="relative h-auto w-full transition duration-300 group-hover:translate-x-2">
    <a href={href} class="block pl-[38px]">
      <h2 class="font-cn text-[36px] font-light leading-[1.45] tracking-tight text-[color:var(--color-text)]">
        {title}
      </h2>
      <p class="mt-1 font-cn text-[32px] font-light leading-[1.45] text-[#aeaeae]">
        {description}
      </p>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-4 font-garamond text-[13px] uppercase tracking-[0.24em] text-[color:var(--color-soft)]">
          {tags.map((tag) => <span>#{tag}</span>)}
        </div>
      )}
    </a>
  </div>
</article>
